# PostgreSQL connection (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://siliconforge:siliconforge@localhost:5432/siliconforge

# Ollama — runs on host machine (use host.docker.internal inside Docker)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ChromaDB persistent storage directory
CHROMA_PERSIST_DIR=./chroma_store

# ArXiv API result limit per query
ARXIV_MAX_RESULTS=5
