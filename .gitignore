# =============================================================================
# SiliconForge AI — .gitignore
# Stack: Python · uv · FastAPI · LangGraph · ChromaDB · PostgreSQL
#        React · Vite · TypeScript · Tailwind · Docker
# =============================================================================


# -----------------------------------------------------------------------------
# Environment & Secrets  ← NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.staging
.env.test
*.env


# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Virtual environments (uv creates .venv by default)
.venv/
venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# Pytest
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
junit*.xml

# MyPy / type checkers
.mypy_cache/
.dmypy.json
.pytype/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# SQLite databases (local dev only; production uses PostgreSQL)
*.sqlite3
*.db


# -----------------------------------------------------------------------------
# ChromaDB — local vector store (regenerated automatically on first run)
# -----------------------------------------------------------------------------
chroma_store/


# -----------------------------------------------------------------------------
# Node.js / Frontend
# -----------------------------------------------------------------------------
node_modules/
frontend/node_modules/

# Vite build output and cache
frontend/dist/
frontend/.vite/
.vite/

# Parcel cache
.cache/
.parcel-cache/

# npm / yarn / pnpm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# TypeScript build info (generated, not source)
*.tsbuildinfo
tsconfig.tsbuildinfo


# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~


# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini


# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Local compose overrides (keep the committed docker-compose.yml)
docker-compose.override.yml
docker-compose.local.yml


# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/


# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.temp
.scratch/
