# =============================================================================
# SiliconForge AI — .gitignore
# Stack: Python · uv · FastAPI · LangGraph · ChromaDB · PostgreSQL
#        React · Vite · TypeScript · Tailwind · Docker
# =============================================================================


# -----------------------------------------------------------------------------
# Environment & Secrets  ← NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local


# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Virtual environments (uv creates .venv by default)
.venv/
venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# Pytest
.pytest_cache/
.coverage
htmlcov/
*.xml

# MyPy / type checkers
.mypy_cache/
.dmypy.json
.pytype/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/


# -----------------------------------------------------------------------------
# ChromaDB — local vector store (regenerated automatically on first run)
# -----------------------------------------------------------------------------
chroma_store/


# -----------------------------------------------------------------------------
# Node.js / Frontend
# -----------------------------------------------------------------------------
node_modules/
frontend/node_modules/

# Vite build output
frontend/dist/
frontend/.vite/

# Parcel cache
.cache/
.parcel-cache/

# npm / yarn / pnpm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~


# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini


# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Docker volumes are managed by Docker; no local artifacts to ignore here.
# Uncomment if you generate compose override files locally:
# docker-compose.override.yml


# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/


# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.temp
.scratch/
